ADMIN_PASSWORD=your_admin_password_here
POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_URL=postgres://bambu:your_postgres_password_here@localhost:5432/bambu_genius

# 必填：SvelteKit 实际访问地址（含协议和端口），用于正确生成 URL 和 cookie
# HTTP 部署示例：
ORIGIN=http://your-server-ip-or-domain:3000
# HTTPS 部署示例：
# ORIGIN=https://your-domain.com

# 可选：若部署环境需要代理才能访问 makerworld.com.cn，填入代理地址
# HTTPS_PROXY=http://your-proxy:port
